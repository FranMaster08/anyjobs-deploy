# Copiar a .env.backend junto al docker-compose en el VPS (permisos 640).
# No commitear secretos reales.

NODE_ENV=production
APP_PORT=3000
LOG_LEVEL=info
LOG_DEBUG_PAYLOADS=false

DB_TYPE=postgres
DB_HOST=anyjobs-postgres
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=cambiar
DB_DATABASE=anyjobs
DB_SSL=false
DB_LOGGING=false
DB_SYNCHRONIZE=false
DB_MIGRATIONS_RUN=true

JWT_SECRET=cambiar
# Añadir el resto de variables que exija apps/api (ver validación de env del backend).
