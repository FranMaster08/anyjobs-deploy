# Renombrar a .env en /opt/anyjobs/staging
# ANYJOBS_*_IMAGE: sustituir ORG/REPO por el repositorio en minúsculas de GitHub.

ANYJOBS_BACK_IMAGE=ghcr.io/org/anyjobs-back:develop
ANYJOBS_FRONT_IMAGE=ghcr.io/org/anyjobs-front:develop

POSTGRES_USER=postgres
POSTGRES_PASSWORD=cambiar-en-produccion
POSTGRES_DB=anyjobs

ANYJOBS_DB_PORT=5432
ANYJOBS_BACK_PORT=3000
ANYJOBS_FRONT_PORT=4200
LOG_LEVEL=log
