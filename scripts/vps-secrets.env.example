# Copiar a vps-secrets.env (no subir a git) y rellenar.
# Opcional: VPS_SSH_PORT, VPS_DEPLOY_SCRIPT, ANYJOBS_DEPLOY_ROOT
#
# Si usas clave SSH en archivo aparte (recomendado):
#   ./sync-vps-secrets-to-github-environments.sh vps-secrets.env ~/.ssh/tu_vps_key
# entonces NO incluyas VPS_SSH_PRIVATE_KEY aquí.

VPS_HOST=
VPS_USER=
